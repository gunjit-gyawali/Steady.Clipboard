{
  "manifest_version": 3,
  "name": "Stedy Clipboard",
  "version": "1.0",
  "description": "Save and manage your text clips persistently",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Stedy Clipboard"
  },
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}